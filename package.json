{
  "name": "sichuan-image-station",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:doctor": "PRISMA_LOG_LEVEL=silent tsx scripts/dev-check.ts",
    "build": "NEXT_PRIVATE_BUILD_WORKER=0 next build && mkdir -p .next/standalone/.next && rm -rf .next/standalone/.next/static && cp -R .next/static .next/standalone/.next/static",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx workers/generation.worker.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.6",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.14.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "prisma": "^6.16.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "15.5.18",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
