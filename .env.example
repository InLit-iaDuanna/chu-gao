NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
ENCRYPTION_KEY=

DATABASE_URL=postgresql://app:CHANGE_ME@postgres:5432/app
POSTGRES_PASSWORD=CHANGE_ME
REDIS_URL=redis://redis:6379

S3_ENDPOINT=https://cos.ap-chongqing.myqcloud.com
S3_REGION=ap-chongqing
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ai-images-1300000000
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL=

DEFAULT_USER_CREDITS=100
MAX_REFERENCE_IMAGES=16
MAX_UPLOAD_SIZE_MB=10
GENERATION_TIMEOUT_MS=300000
SIGNED_URL_EXPIRES_SECONDS=3600

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_AFTER_LOGIN
ADMIN_NAME=Admin
ADMIN_IP_ALLOWLIST=
RATE_LIMIT_LOGIN_PER_MIN=5

IMAGE2_PROVIDER_NAME=sub2api
IMAGE2_PROVIDER_PROTOCOL=OPENAI_IMAGES
IMAGE2_WIRE_API=images
IMAGE2_BASE_URL=https://api.xpzhao.top
IMAGE2_API_KEY=
IMAGE2_MODELS_SUPPORTED=gpt-image-2
IMAGE2_PRIORITY=100
IMAGE2_COST_MULTIPLIER=1
IMAGE2_PROVIDER_NOTE=OpenAI Images compatible image2 provider

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.xpzhao.top
SUB2API_RESPONSES_MODEL=gpt-5.5
CONVERSATION_COMPILER_MODEL=gpt-5.5
CONVERSATION_COMPILER_REASONING=low

LOG_LEVEL=info
